<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Email Blast Effectiveness — Solviva</title>
<style>
  :root {
    --lime: #d2ff1e;
    --dark-green: #1f522b;
    --blue: #006ac6;
    --bg: #0d1117;
    --card: #161b22;
    --card-border: #30363d;
    --text: #e6edf3;
    --text-muted: #8b949e;
    --won: #2ea043;
    --parked: #da3633;
    --sql: #006ac6;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
         background: var(--bg); color: var(--text); line-height: 1.5; }

  .header { background: linear-gradient(135deg, var(--dark-green) 0%, #0d1117 100%);
             padding: 32px 40px; border-bottom: 3px solid var(--lime); }
  .header h1 { font-size: 28px; font-weight: 700; color: var(--lime); }
  .header .subtitle { color: var(--text-muted); font-size: 14px; margin-top: 4px; }
  .header .meta { color: var(--text-muted); font-size: 12px; margin-top: 8px; }

  .container { max-width: 1280px; margin: 0 auto; padding: 24px 40px 60px; }

  /* KPI row */
  .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
              gap: 16px; margin-bottom: 32px; }
  .kpi { background: var(--card); border: 1px solid var(--card-border); border-radius: 12px;
          padding: 20px; text-align: center; }
  .kpi-val { font-size: 32px; font-weight: 700; color: var(--lime); }
  .kpi-lbl { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }
  .kpi.accent .kpi-val { color: var(--blue); }
  .kpi.warn .kpi-val { color: #da3633; }
  .kpi.good .kpi-val { color: var(--won); }

  h2 { font-size: 20px; color: var(--lime); margin: 32px 0 16px;
       border-bottom: 1px solid var(--card-border); padding-bottom: 8px; }
  h4 { font-size: 14px; color: var(--text-muted); margin: 12px 0 8px; }

  /* Transitions */
  .trans-table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
  .trans-table th { text-align: left; font-size: 12px; color: var(--text-muted);
                     text-transform: uppercase; padding: 8px 12px; border-bottom: 1px solid var(--card-border); }
  .trans-table td { padding: 10px 12px; border-bottom: 1px solid #21262d; }
  .trans-table .num { font-weight: 700; font-size: 18px; color: var(--lime); text-align: right; }
  .arrow { color: var(--text-muted); margin: 0 6px; }

  .stage-tag { display: inline-block; padding: 2px 10px; border-radius: 12px;
                font-size: 12px; font-weight: 600; background: #30363d; color: var(--text); }
  .tag-won { background: rgba(46,160,67,.2); color: #56d364; }
  .tag-parked { background: rgba(218,54,51,.15); color: #f85149; }
  .tag-sql { background: rgba(0,106,198,.2); color: #58a6ff; }

  /* Leads table */
  .leads-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .leads-table th { text-align: left; font-size: 11px; color: var(--text-muted);
                     text-transform: uppercase; padding: 10px 12px;
                     border-bottom: 2px solid var(--card-border); position: sticky; top: 0;
                     background: var(--bg); }
  .leads-table td { padding: 10px 12px; border-bottom: 1px solid #21262d; vertical-align: top; }
  .leads-table tr:hover { background: #1c2128; }
  .lead-id { color: var(--text-muted); font-family: monospace; }
  .email { color: var(--text-muted); font-size: 12px; }
  .icon-yes { color: var(--won); font-weight: 700; }
  .icon-no { color: #484f58; }
  .transition { margin-bottom: 4px; }
  .transition .dt { color: var(--text-muted); font-size: 11px; margin-right: 6px; }
  .batch { color: var(--text-muted); font-size: 11px; }

  /* Batch cards */
  .batch-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 20px; }
  .batch-card { background: var(--card); border: 1px solid var(--card-border);
                 border-radius: 12px; padding: 20px; }
  .batch-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .batch-id { font-weight: 700; color: var(--lime); }
  .batch-date { color: var(--text-muted); font-size: 13px; }
  .batch-kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 12px; }
  .mini-kpi { text-align: center; padding: 8px 4px; background: #0d1117; border-radius: 8px; }
  .mini-kpi.highlight { background: rgba(210,255,30,.06); }
  .mini-val { display: block; font-size: 18px; font-weight: 700; color: var(--text); }
  .mini-lbl { font-size: 10px; color: var(--text-muted); text-transform: uppercase; }
  .mini-kpi.highlight .mini-val { color: var(--lime); }

  .dist-chart { margin-bottom: 8px; }
  .dist-row { display: flex; align-items: center; margin-bottom: 4px; }
  .dist-label { width: 140px; font-size: 12px; color: var(--text-muted); flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .dist-bar-bg { flex: 1; height: 14px; background: #21262d; border-radius: 7px; overflow: hidden; margin: 0 8px; }
  .dist-bar { height: 100%; background: linear-gradient(90deg, var(--dark-green), var(--lime)); border-radius: 7px; }
  .dist-count { font-size: 12px; font-weight: 600; width: 36px; text-align: right; }

  /* Insight box */
  .insight { background: rgba(210,255,30,.06); border: 1px solid rgba(210,255,30,.15);
              border-radius: 12px; padding: 20px; margin-top: 24px; }
  .insight h3 { color: var(--lime); font-size: 16px; margin-bottom: 8px; }
  .insight p { color: var(--text-muted); font-size: 14px; line-height: 1.6; }
  .insight strong { color: var(--text); }

  @media (max-width: 768px) {
    .container { padding: 16px; }
    .kpi-row { grid-template-columns: repeat(2, 1fr); }
    .batch-kpis { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head>
<body>

<div class="header">
  <h1>Email Blast Effectiveness Dashboard</h1>
  <div class="subtitle">&ldquo;Our lowest prices yet - Until May 31 only.&rdquo;</div>
  <div class="meta">Generated 2026-03-24 18:16 &middot; 3 mailing batch(es) analyzed</div>
